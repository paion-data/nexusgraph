{
  "env": {
    "node": true,
    "browser": true
  },
  "root": true,
  "extends": ["eslint:recommended", "plugin:@typescript-eslint/recommended", "prettier"],
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint", "header"],
  "rules": {
    "no-console": "error",
    "max-len": [
      "error",
      {
        "code": 120,
        "comments": 120,
        "ignoreUrls": true
      }
    ],
    "header/header": [2, "line", " Copyright 2023 Paion Data. All rights reserved."]
  }
}
